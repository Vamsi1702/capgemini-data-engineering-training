# Description: PySpark ETL pipeline for sales analysis
# ============================================

# Step 1 - Read customers data from CSV
customers_df = spark.read.format("csv") \
    .option("header", "true") \
    .load("/samples/customers.csv")

# Step 2 - Read sales data from CSV
sales_df = spark.read.format("csv") \
    .option("header", "true") \
    .load("/samples/sales.csv")

# Step 3 - Clean sales data by removing nulls and invalid amounts
sales_df = sales_df.filter(
    col("total_amount").isNotNull() &
    col("customer_id").isNotNull() &
    (col("total_amount") > 0)
)

# Exercise 1 - Calculate total revenue generated each day
daily_sales = sales_df \
    .groupBy("sale_date") \
    .agg(_sum("total_amount").alias("daily_total")) \
    .orderBy("sale_date")

# Exercise 2 - Calculate total revenue generated by each city
city_revenue = sales_df \
    .join(customers_df, on="customer_id", how="inner") \
    .groupBy("city") \
    .agg(_sum("total_amount").alias("city_revenue")) \
    .orderBy("city_revenue", ascending=False)

# Exercise 3 - Find customers who placed more than 2 orders
repeat_customers = sales_df \
    .groupBy("customer_id") \
    .agg(count("sale_id").alias("order_count")) \
    .filter(col("order_count") > 2)

# Exercise 4 - Find highest spending customer in each city
top_spenders = sales_df \
    .join(customers_df, on="customer_id", how="inner") \
    .groupBy("city", "customer_id") \
    .agg(_sum("total_amount").alias("total_spent")) \
    .orderBy("city", "total_spent", ascending=False)

# Exercise 5 - Build final reporting table with customer details
final_report = sales_df \
    .join(customers_df, on="customer_id", how="inner") \
    .groupBy("customer_id", "first_name", "city") \
    .agg(
        _sum("total_amount").alias("total_spent"),
        count("sale_id").alias("order_count")
    ) \
    .orderBy("total_spent", ascending=False)
